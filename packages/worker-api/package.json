  },
  "dependencies": {
    "@authmaster/shared": "file:../shared",
    "@simplewebauthn/server": "^13.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4",
    "wrangler": "^3.20.0"
  }
