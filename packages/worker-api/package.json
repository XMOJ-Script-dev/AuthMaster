{
  "name": "@authmaster/worker-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "build": "tsc && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "test": "vitest",
